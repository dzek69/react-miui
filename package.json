{
  "name": "react-miui",
  "version": "0.34.0+",
  "author": "Jacek Nowacki",
  "license": "MIT",
  "scripts": {
    "test": "NODE_ENV=test jest",
    "docs": "typedoc src/index.ts --skipErrorChecking --out docs --includeVersion",
    "compile": "pnpm run compile:esm && pnpm run compile:cjs",
    "compile:esm": "rm -rf esm && tsc --project tsconfig.esm.json && node ./build-scripts/compile.esm.after.mjs",
    "compile:cjs": "rm -rf dist && tsc --project tsconfig.cjs.json && node ./build-scripts/compile.cjs.after.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "ezlint src",
    "lint:fix": "pnpm run lint --fix",
    "prepack": "pnpm run compile",
    "prepublishOnly": "pnpm test && pnpm run docs",
    "start:dev": "pnpm run storybook",
    "updates": "pnpm dlx npm-check-updates --dep prod",
    "updates:dev": "pnpm dlx npm-check-updates --dep dev",
    "updates:all": "pnpm dlx npm-check-updates",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./esm/index.d.ts",
      "default": "./esm/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./esm/index.d.ts",
  "module": "./esm/index.js",
  "dependencies": {
    "@bedrock-layout/use-forwarded-ref": "^2.0.17",
    "@ezez/utils": "^3.0.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@stitches/react": "^1.2.8",
    "classnames": "^2.5.1",
    "oop-timers": "^5.2.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-typescript": "^7.28.5",
    "@ezez/eslint": "^9.39.4",
    "@ezez/hooks": "^2.3.1",
    "@icon-park/react": "^1.4.2",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-onboarding": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "babel-plugin-module-extension": "^0.1.3",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint-plugin-storybook": "^10.4.0",
    "jest": "^30.4.2",
    "must": "^0.13.4",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-use": "^17.6.0",
    "resolve-tspaths": "^0.8.23",
    "storybook": "^10.4.0",
    "typedoc": "0.27.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "libraryTemplate": {
    "version": "3.14.0",
    "language": "typescript",
    "fixDefaultForCommonJS": true,
    "jsx": true
  },
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "patchedDependencies": {
      "@stitches/react@1.2.8": "patches/@stitches__react@1.2.8.patch"
    }
  }
}

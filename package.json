{
  "name": "react-miui",
  "version": "0.30.1",
  "author": "Jacek Nowacki",
  "license": "MIT",
  "scripts": {
    "test": "NODE_ENV=test jest",
    "docs": "typedoc src/index.ts --skipErrorChecking --out docs --includeVersion",
    "compile": "pnpm run compile:esm && pnpm run compile:cjs",
    "compile:esm": "rm -rf esm && tsc --project tsconfig.esm.json && node ./build-scripts/compile.esm.after.mjs",
    "compile:cjs": "rm -rf dist && tsc --project tsconfig.cjs.json && node ./build-scripts/compile.cjs.after.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "ezlint src",
    "lint:fix": "pnpm run lint --fix",
    "prepare": "patch-package",
    "prepack": "pnpm run compile",
    "prepublishOnly": "pnpm test && pnpm run docs",
    "start:dev": "pnpm run storybook",
    "updates": "pnpm dlx npm-check-updates --dep prod",
    "updates:dev": "pnpm dlx npm-check-updates --dep dev",
    "updates:all": "pnpm dlx npm-check-updates",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./esm/index.d.ts",
      "default": "./esm/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./esm/index.d.ts",
  "module": "./esm/index.js",
  "dependencies": {
    "@bedrock-layout/use-forwarded-ref": "^2.0.17",
    "@ezez/utils": "^3.0.0",
    "@stitches/react": "^1.2.8",
    "classnames": "^2.5.1",
    "oop-timers": "^5.1.0",
    "patch-package": "^8.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@ezez/eslint": "^9.37.7",
    "@ezez/hooks": "^2.2.0",
    "@icon-park/react": "^1.4.2",
    "@storybook/addon-docs": "^9.1.10",
    "@storybook/addon-onboarding": "^9.1.10",
    "@storybook/react-vite": "^9.1.10",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "babel-plugin-module-extension": "^0.1.3",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint-plugin-storybook": "^0.6.15",
    "jest": "^29.7.0",
    "must": "^0.13.4",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-use": "^17.5.1",
    "resolve-tspaths": "^0.8.23",
    "storybook": "^9.1.10",
    "ts-node": "^10.9.2",
    "typedoc": "0.27.6",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "libraryTemplate": {
    "version": "3.14.0",
    "language": "typescript",
    "fixDefaultForCommonJS": true,
    "jsx": true
  }
}
